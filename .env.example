# BrainCoin — Environment Variables
# Copy this to .env in the project root (next to docker-compose.yml)
# and fill in your values before running docker compose up.

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic Claude API key — used to auto-generate quiz questions.
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# JWT signing secret — change this in production!
# JWT_SECRET=br41nc01n-super-secret-2026-change-in-production

# CORS allowed origin for the backend
# CORS_ORIGIN=http://localhost:3000
