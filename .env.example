# BrainCoin — Environment Variables
# Copy this to .env in the project root (next to docker-compose.yml)
# and fill in your values before running docker compose up.

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic Claude API key — used to auto-generate quiz questions.
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# JWT signing secret — change this in production!
# JWT_SECRET=br41nc01n-super-secret-2026-change-in-production

# CORS allowed origin for the backend
# CORS_ORIGIN=http://localhost:3000

# ── Stripe (subscription billing) ─────────────────────────────────────────────

# Stripe secret key (sk_live_... in production, sk_test_... for testing)
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret — get from Stripe CLI or dashboard after creating webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price ID for the €5/month recurring plan
# Create it in Stripe Dashboard → Products → Add product → Add price (€5, recurring, monthly)
STRIPE_PRICE_ID=price_...

# Public URL of your frontend — used for Stripe redirect after checkout
FRONTEND_URL=http://localhost:3000
